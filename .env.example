# Free Gemini API keys (used in order, falls back on rate limit)
GEMINI_API_KEY_1=your_free_key_1
GEMINI_API_KEY_2=your_free_key_2
GEMINI_API_KEY_3=your_free_key_3

# Paid key (last resort fallback)
GEMINI_API_KEY_PAID=your_paid_key

# Single key mode (backwards compatible, used if no numbered keys found)
# GEMINI_API_KEY=your_key

# API Gateway URL (set after cdk deploy, optional for local direct mode)
# AIP_API_URL=https://xxxxx.execute-api.ap-northeast-1.amazonaws.com/prod
